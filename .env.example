# Server
PORT=8010
APP_BASE_URL=http://localhost:8010
DB_PATH=./data/inventory.db
DATABASE_URL=
DB_BACKUP_INTERVAL_MS=60000

# JWT
JWT_SECRET=change_me
MPESA_ENCRYPTION_SECRET=change_me_too

# WebAuthn (optional overrides)
# WEB_AUTHN_ORIGIN=https://your-domain.com
# WEB_AUTHN_RPID=your-domain.com

# Bootstrap admin (only used when users table is empty)
# ADMIN_BOOTSTRAP_USERNAME=admin@site
# ADMIN_BOOTSTRAP_EMAIL=admin@gmail.com
# ADMIN_BOOTSTRAP_PASSWORD=StrongPass123

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

MAIL_FROM_NAME=SmartInventory Pro
MAIL_FROM_ADDRESS=your_from_address@gmail.com
MAIL_REPLY_TO=your_reply_to@gmail.com